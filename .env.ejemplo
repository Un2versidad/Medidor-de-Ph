#  Dashboard Medidor de pH del Agua — Plantilla de Credenciales
#  Copia este archivo como .env y rellena los valores reales.

# ── Discord Webhook ───────────────────────────────────────────
# Crea un Webhook en: Canal > Configuración > Integraciones > Webhooks
# La URL tiene el formato: https://discord.com/api/webhooks/<id>/<token>
DISCORD_WEBHOOK_URL=

# ── Correo vía Resend API ─────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
# Destinatarios separados por coma: correo1@gmail.com,correo2@gmail.com
ALERT_RECIPIENTS=

# ── Cooldown entre alertas por ubicación (segundos) ──────────
ALERT_COOLDOWN_S=300

# ── Frontend/Backend modo de prueba ───────────────────────────
# true = usa datos mockup y no depende de hardware en UI
# false = modo real con Arduino
TEST_MODE=true
# segundos mínimos recomendados antes de guardar lectura al cambiar de ubicación
SENSOR_CALIBRATION_S=30

# -- OpenRouter Chatbot ----------------------------------------
OPENROUTER_API_KEY=
# Modelo de chat (recomendado: openrouter/auto)
OPENROUTER_MODEL=openrouter/free

# -- Supabase sync ----------------------------------
# Requiere crear el esquema 3FN en Supabase usando:
# python/supabase_schema_3fn.sql
SUPABASE_SYNC_ENABLED=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Nombre de la función RPC en Supabase para ingestar lecturas.
# Si usas el script python/supabase_schema_3fn.sql, deja este valor tal cual.
SUPABASE_RPC_INGEST=ingest_water_reading

# -- Identidad del dispositivo ---------------------------------
DEVICE_UID=uno-q-dashboard
